# ============================
# StageVault — переменные окружения
# Скопируй этот файл: cp .env.example .env
# ============================

# --- База данных ---
DATABASE_URL=postgresql://stagevault:stagevault@localhost:5432/stagevault

# --- MinIO (S3-совместимое хранилище) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=stagevault-files
S3_REGION=us-east-1

# --- JWT ---
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- Email (SMTP) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@stage-vault.ru
SMTP_PASS=your-smtp-password
SMTP_FROM="StageVault <noreply@stage-vault.ru>"

# --- ИИ (LLM API) ---
AI_PROVIDER=openai
AI_API_KEY=sk-your-api-key
AI_MODEL=gpt-4o-mini

# --- Приложение ---
APP_URL=http://localhost:5173
API_URL=http://localhost:3000
API_PORT=3000
NODE_ENV=development
